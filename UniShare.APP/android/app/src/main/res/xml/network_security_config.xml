<?xml version="1.0" encoding="utf-8"?>
<!--
  Allows plain HTTP (cleartext) traffic ONLY to the local dev/test backend
  addresses below. From Android 9 (API 28) onward, the OS blocks all
  cleartext HTTP by default, so without this, every API call to an
  http:// backend fails with "CLEARTEXT communication not permitted".

  Do NOT add production domains here — production should use HTTPS and
  rely on the default (secure) config instead.
-->
<network-security-config>
    <domain-config cleartextTrafficPermitted="true">
        <!-- Android emulator alias for the host machine -->
        <domain includeSubdomains="false">10.0.2.2</domain>
        <!-- Real-device LAN testing: host machine's LAN IP -->
        <domain includeSubdomains="false">192.168.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
    </domain-config>
</network-security-config>